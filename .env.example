# --- Database (SQLite by default — zero config) -----------------------------
# To use PostgreSQL instead, set:
#   DATABASE_URL="postgresql://wl:wl@localhost:5432/wl?schema=public"
# and update prisma/schema.prisma `provider` to "postgresql".
DATABASE_URL="file:./dev.db"

# --- Auth -------------------------------------------------------------------
# In production, generate with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me-in-production-please-do-it"
AUTH_URL="http://localhost:3010"
AUTH_TRUST_HOST="true"

# --- Email (optional) -------------------------------------------------------
# If SMTP_HOST is unset OR unreachable, password-reset URLs are logged to the
# server console instead of being emailed. Useful for first-run dev.
#
# To use Mailpit: `docker compose up -d mailpit`, then uncomment:
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_FROM="no-reply@wl-web-app.local"

# --- App --------------------------------------------------------------------
APP_URL="http://localhost:3010"
MAX_AVATAR_BYTES="2097152"

# --- docs/solutions browse (optional) ---------------------------------------
# When set, the /super-admin/docs-solutions browse page renders each row's
# source link as a clickable GitHub URL. Must start with `https://` — values
# with any other scheme are ignored as a safety guard.
# GITHUB_REPO_URL="https://github.com/mr-christian-jacobsen/wl-web-app"
