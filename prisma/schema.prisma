generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  avatarUrl       String?
  isSuperAdmin    Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  usageSessions      UsageSession[]
  emails             Email[]
}

model UsageSession {
  id           String    @id @default(cuid())
  userId       String
  startedAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  endedAt      DateTime?

  // Server-detected
  userAgent String?
  ipHash    String?

  // Parsed from User-Agent
  os             String?
  osVersion      String?
  browser        String?
  browserVersion String?
  deviceType     String? // "desktop" | "mobile" | "tablet" | "other"

  // Reported by the client
  screenWidth    Int?
  screenHeight   Int?
  viewportWidth  Int?
  viewportHeight Int?
  timezone       String?
  language       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
  @@index([startedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  subject     String
  bodyText    String
  bodyHtml    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  purpose   String // "signup" | "change"
  newEmail  String? // populated when purpose == "change"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Audit log of every transactional email the app attempts to send.
/// Rows are created even when delivery fails or is skipped (no SMTP configured),
/// so the table is the source of truth for "did the user get the email?".
model Email {
  id          String   @id @default(cuid())
  to          String
  type        String // "user_invitation" | "email_verification" | "password_reset" | "email_change_confirmation"
  templateKey String? // null when the hardcoded fallback was rendered
  subject     String
  bodyText    String
  bodyHtml    String?
  status      String   @default("pending") // "pending" | "sent" | "failed" | "skipped"
  error       String?
  sentAt      DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sentAt])
  @@index([userId])
  @@index([type])
}

/// Free-form key/value store for runtime-editable system configuration
/// (e.g. SMTP credentials managed from /super-admin/system-settings).
/// Values present here override the corresponding env vars at read time.
model SystemSetting {
  key       String   @id
  value     String?
  /// When true, the value is masked in API responses; updates only apply when
  /// a non-empty replacement is supplied.
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
