generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  /// Public URL the UI renders for the avatar (e.g. /api/avatar/{id}?v={ms}).
  /// Null when no avatar is set. Updated whenever `avatar` changes.
  avatarUrl       String?
  /// Avatar bytes, stored directly in the row. Cropped + JPEG-encoded by the
  /// client before upload, validated for MIME + magic + size on the server.
  avatar          Bytes?
  /// Mime type of the bytes in `avatar` — needed by the GET /api/avatar route
  /// to set Content-Type.
  avatarMime      String?
  isSuperAdmin    Boolean   @default(false)
  emailVerifiedAt DateTime?
  /// Preferred language for emails and other user-facing content. Null
  /// means "follow the system default" — the email pipeline resolves
  /// templates via `(key, user.languageId ?? defaultId) → (key, defaultId)
  /// → hardcoded fallback`. Languages are managed in
  /// `/super-admin/languages`; deleting one nulls this column rather than
  /// the user row.
  languageId      String?
  language        Language? @relation(fields: [languageId], references: [id], onDelete: SetNull)
  /// "light" | "dark" | "system" (or null = system).
  /// Resolved server-side at request time; the inline script in the root
  /// layout applies the OS preference for "system" before first paint.
  themePreference String?
  /// When true, the user has opted out of `task_created` notification emails.
  /// In-app notifications cannot be disabled. Surfaced as a toggle on
  /// /profile and threaded through the JWT session callback so the
  /// notification dispatcher can short-circuit email sends without an
  /// extra DB query. Default false (emails enabled) per KTD5.
  taskEmailsOptOut Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  usageSessions      UsageSession[]
  emails             Email[]
  logEntries         LogEntry[]
  /// Per-user task instances created by the tasks subsystem (signup
  /// trigger, manual admin assign, backfill on enable, recurring,
  /// specific date). See `Task` and `TaskInstance`.
  taskInstances      TaskInstance[]
  /// Per-user in-app notifications. v1 only carries `task_created`
  /// notifications; the entity is general so non-task notification
  /// types can join without schema churn.
  notifications      Notification[]
  /// Reverse relation for `TaskInstance.assignedByAdmin` — task
  /// instances this user (as super admin) manually assigned to others.
  assignedTaskInstances  TaskInstance[] @relation("TaskInstanceAssignedByAdmin")
  /// Reverse relation for `TaskInstance.completedByAdmin` — task
  /// instances this user (as super admin) marked complete on behalf
  /// of another user.
  completedTaskInstances TaskInstance[] @relation("TaskInstanceCompletedByAdmin")

  @@index([languageId])
}

/// Admin-defined ordered survey. Steps live in a separate table so they
/// can be re-ordered cheaply via `position` (0-based) without rewriting
/// the whole survey row. Surveys are global resources — any super admin
/// can manage any survey, matching the EmailTemplate / SystemSetting
/// pattern.
model Survey {
  id          String    @id @default(cuid())
  /// 6-char [a-zA-Z] random handle used as the public URL segment
  /// (`/s/{publicSlug}`). Generated at creation time with retry-on-
  /// collision (see `src/lib/survey-slug.ts`). The cuid id is kept as
  /// the primary key and is used everywhere admin-side; we don't
  /// expose it publicly so leaking one survey's URL doesn't help an
  /// attacker enumerate others.
  publicSlug  String    @unique
  name        String
  description String?
  /// Toggled by an admin from the editor. Public `/s/{publicSlug}`
  /// returns 404 while false; the admin-only
  /// `/super-admin/surveys/[id]/preview` page renders the form
  /// regardless so admins can dry-run drafts.
  published   Boolean   @default(false)
  /// First time the survey was published. Lets us tell "draft, never
  /// shipped" apart from "was live, taken back down".
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  steps     SurveyStep[]
  responses SurveyResponse[]

  @@index([updatedAt])
}

model SurveyStep {
  id        String   @id @default(cuid())
  surveyId  String
  /// 0-based ordinal within the survey. Reordered by rewriting all
  /// positions in a single transaction; gaps between values are not
  /// meaningful.
  position  Int
  /// Step kind — one of the keys in `STEP_TYPES` (see src/lib/step-types.ts).
  /// Stored as a string so adding a new type doesn't need a migration.
  type      String
  title     String
  notes     String?
  /// Newline-separated option labels. Only meaningful for choice-style
  /// types (`single_choice`, `multi_choice`); null otherwise. Stored as
  /// a single string instead of a child table because options are
  /// always read together with the step and never queried by value.
  options   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([surveyId, position])
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  submittedAt DateTime @default(now())
  /// SHA-256 of the submitter IP — kept so admins can spot abuse without
  /// storing raw addresses. Hash fields are skipped by the DB-write
  /// normaliser in `src/lib/db.ts` (see `NEVER_NORMALIZE`).
  ipHash      String?
  userAgent   String?

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([surveyId, submittedAt])
}

model SurveyAnswer {
  id         String @id @default(cuid())
  responseId String
  stepId     String
  /// Free-form rendering of the user's answer. Choice-style types store
  /// the chosen option label; multi-choice joins multiple labels with
  /// "\n". A single string keeps reading simple at the cost of needing
  /// to split on the client when re-rendering multi_choice.
  valueText  String

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  step     SurveyStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([stepId])
}

model UsageSession {
  id           String    @id @default(cuid())
  userId       String
  startedAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  endedAt      DateTime?

  // Server-detected
  userAgent String?
  ipHash    String?

  // Parsed from User-Agent
  os             String?
  osVersion      String?
  browser        String?
  browserVersion String?
  deviceType     String? // "desktop" | "mobile" | "tablet" | "other"

  // Reported by the client
  screenWidth    Int?
  screenHeight   Int?
  viewportWidth  Int?
  viewportHeight Int?
  timezone       String?
  language       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  logEntries LogEntry[]

  @@index([userId, lastActiveAt])
  @@index([startedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Admin-defined override of one transactional email per (key, language)
/// pair. Keys are listed in `KNOWN_TEMPLATES` (`src/lib/templates.ts`);
/// rendering falls through `(key, requestedLanguage) → (key, default) →
/// hardcoded fallback` in `renderTemplateByKey`. The send pipeline
/// currently always asks for the default language — once a runtime
/// language source exists (User.language column, request locale, …),
/// the third arg of `renderTemplateByKey` plugs straight in.
model EmailTemplate {
  id          String   @id @default(cuid())
  key         String
  /// Language this row applies to. Required — every template row is
  /// for some specific locale, including the seeded default.
  languageId  String
  language    Language @relation(fields: [languageId], references: [id], onDelete: Restrict)
  name        String
  subject     String
  bodyText    String
  bodyHtml    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, languageId])
  @@index([languageId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  purpose   String // "signup" | "change"
  newEmail  String? // populated when purpose == "change"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Audit log of every transactional email the app attempts to send.
/// Rows are created even when delivery fails or is skipped (no SMTP configured),
/// so the table is the source of truth for "did the user get the email?".
model Email {
  id          String   @id @default(cuid())
  to          String
  type        String // "user_invitation" | "email_verification" | "password_reset" | "email_change_confirmation" | "task_created"
  templateKey String? // null when the hardcoded fallback was rendered
  subject     String
  bodyText    String
  bodyHtml    String?
  status      String   @default("pending") // "pending" | "sent" | "failed" | "skipped"
  error       String?
  sentAt      DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sentAt])
  @@index([userId])
  @@index([type])
}

/// Free-form key/value store for runtime-editable system configuration
/// (e.g. SMTP credentials managed from /super-admin/system-settings).
/// Values present here override the corresponding env vars at read time.
model SystemSetting {
  key       String   @id
  value     String?
  /// When true, the value is masked in API responses; updates only apply when
  /// a non-empty replacement is supplied.
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Admin-managed locale: a (country, language) pair drawn from the
/// curated dataset in `src/lib/locales.ts` (ISO 3166-1 alpha-2 +
/// ISO 639-1). Like `EmailTemplate` and `Survey` this is a global
/// resource — no `userId`. Seeded with one row (`isDefault = true`)
/// that may never be deleted; see `ensureDefaultLanguage` and the
/// guard inside the DELETE handler.
model Language {
  id           String   @id @default(cuid())
  /// ISO 3166-1 alpha-2, e.g. "GB", "US", "DK". Stored upper-case
  /// because country codes are case-insensitive but conventionally
  /// rendered upper. The DB-write normaliser only trims; case is
  /// enforced by the Zod schema in `src/lib/validators.ts`.
  countryCode  String
  /// ISO 639-1 (or BCP-47 short tag for "fil"). Lower-case by
  /// convention; same caveat about case as `countryCode`.
  languageCode String
  /// True for the seeded English/UK row. Used as the don't-delete
  /// flag — the DELETE handler refuses any row where this is true.
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  emailTemplates EmailTemplate[]
  users          User[]
  translations   Translation[]

  @@unique([countryCode, languageCode])
  @@index([countryCode])
}

/// One translatable user-facing string. The `key` is the stable
/// identifier referenced from code via `t("key")`; `name` and
/// `description` are admin-facing labels shown on
/// `/super-admin/translations` so the admin can tell where the string
/// is used without reading source. Source of truth for which keys
/// exist lives in `src/lib/translations.ts` (`KNOWN_TRANSLATIONS`);
/// rows here are upserted from that registry on boot via
/// `syncTranslationKeys` so adding a string in code automatically
/// surfaces it in the admin UI for every language.
model TranslationKey {
  id          String        @id @default(cuid())
  /// Dot-separated lowercase identifier, e.g. "profile.title" or
  /// "auth.login.button.submit". Enforced by the Zod schema in
  /// `src/lib/validators.ts`.
  key         String        @unique
  /// Short human-readable label, e.g. "Profile page title".
  name        String
  /// Optional longer hint about where the string appears.
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  values Translation[]

  @@index([key])
}

/// One translated value for a (`translationKey`, `language`) pair.
/// Edits update existing rows; missing rows fall through to the
/// default-language value, which falls through to the key string
/// itself, so a deploy with new keys never shows a blank UI.
model Translation {
  id               String   @id @default(cuid())
  translationKeyId String
  languageId       String
  value            String
  /// Provenance of the current value:
  ///   "human"  — set by an admin in the editor (default).
  ///   "auto"   — produced by the auto-translate provider and either
  ///              committed directly or saved without further edits.
  /// Editing a row in the UI flips this back to "human" on save so
  /// the system always knows which strings still need a human review.
  source           String   @default("human")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  translationKey TranslationKey @relation(fields: [translationKeyId], references: [id], onDelete: Cascade)
  language       Language       @relation(fields: [languageId], references: [id], onDelete: Restrict)

  @@unique([translationKeyId, languageId])
  @@index([languageId])
  @@index([source])
}

/// Append-only log of runtime errors, warnings and explicit info events.
/// Identical events collapse onto a single row via the unique `fingerprint`
/// hash; `count` and `lastOccurredAt` advance on every recurrence so a
/// flapping bug doesn't flood the table.
model LogEntry {
  id              String   @id @default(cuid())
  level           String // "error" | "warning" | "info"
  source          String // "server" | "client"
  fingerprint     String   @unique
  /// Error class name when known: "TypeError", "PrismaClientKnownRequestError", etc.
  name            String?
  message         String
  stack           String?
  /// JSON blob of caller-supplied context. Never includes request bodies or
  /// form data unless the caller passed it deliberately.
  context         String?
  // Server-side request metadata.
  method          String?
  path            String?
  statusCode      Int?
  // Client-side request metadata.
  url             String?
  userAgent       String?

  count           Int      @default(1)
  firstOccurredAt DateTime @default(now())
  lastOccurredAt  DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Latest active UsageSession for the user at the time of the event, when
  /// known. Lets the detail modal surface OS/browser/device without needing
  /// to re-parse the user-agent.
  sessionId String?
  session   UsageSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([level, lastOccurredAt])
  @@index([userId])
  @@index([source])
  @@index([sessionId])
}

/// Admin-defined task template. Like `Survey` and `EmailTemplate`,
/// `Task` is a global resource (no `userId`) — any super admin can
/// create / edit / enable / disable / delete any task. Per-user
/// state lives in `TaskInstance`. Triggers live in the `TaskTrigger`
/// child table so the four trigger shapes (signup, manual_assign,
/// recurring, specific_date) can carry kind-specific config (interval
/// days, date list) without forcing booleans + JSON onto this row.
model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  /// Optional auto-complete predicate key from `KNOWN_PREDICATES`
  /// in `src/lib/predicates.ts`. Null means "manual / trust user" —
  /// only user clicks or admin overrides complete the task.
  predicateKey  String?
  /// Admin-toggled. Disabled tasks do not produce new instances via
  /// signup / scheduler / backfill (existing instances stay visible
  /// per the resolved-2026-05-31 decision in the plan).
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  triggers  TaskTrigger[]
  instances TaskInstance[]

  @@index([enabled])
  @@index([updatedAt])
}

/// One trigger row per discrete trigger configuration. `kind` is a
/// string discriminator matching one of: `signup`, `manual_assign`,
/// `recurring`, `specific_date`. `intervalDays` carries the recurring
/// interval; `dateList` carries newline-joined `YYYY-MM-DD` strings
/// for specific-date triggers; both are null for `signup` and
/// `manual_assign`. Cascade-deleted with `Task`.
model TaskTrigger {
  id           String   @id @default(cuid())
  taskId       String
  kind         String
  intervalDays Int?
  /// Newline-joined `YYYY-MM-DD` strings. Stored as a single column
  /// instead of a child table because the scheduler's per-tick scan
  /// reads all rows together; KTD3 in the plan documents the
  /// indexability trade-off.
  dateList     String?
  createdAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([kind])
}

/// Per-user task instance. Status is `pending` or `completed`.
/// `source` records how the instance reached `completed`:
///   "predicate" — auto-complete predicate matched
///   "user"      — user clicked Mark complete on /tasks
///   "admin"     — admin marked complete on behalf via instance overview
/// `signature` is the uniqueness scheme per KTD10 in the plan:
///   "signup"                       (signup trigger)
///   "manual:<assignedAtIso>"       (manual admin assignment)
///   "backfill:<enabledAtIso>"      (backfill on enable)
///   "recurring:<cycleStartIso>"    (recurring trigger)
///   "specific-date:<YYYY-MM-DD>"   (specific-date trigger)
/// `assignedByAdminId` and `completedByAdminId` are nullable audit
/// FKs to `User` set when an admin manually assigned the instance
/// (U4) or marked it complete on behalf (U8). Both null for
/// self-completions and predicate-driven completions.
model TaskInstance {
  id                   String    @id @default(cuid())
  taskId               String
  userId               String
  status               String    @default("pending")
  source               String?
  signature            String
  completedAt          DateTime?
  assignedByAdminId    String?
  completedByAdminId   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  task              Task           @relation(fields: [taskId], references: [id], onDelete: Restrict)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByAdmin   User?          @relation("TaskInstanceAssignedByAdmin", fields: [assignedByAdminId], references: [id], onDelete: SetNull)
  completedByAdmin  User?          @relation("TaskInstanceCompletedByAdmin", fields: [completedByAdminId], references: [id], onDelete: SetNull)
  notifications     Notification[]

  @@unique([taskId, userId, signature])
  @@index([userId, status])
  @@index([taskId])
}

/// In-app notification. v1 only carries `task_created` notifications
/// fired when a task instance is created and stays pending after
/// predicate evaluation. Read/unread is independent of the linked
/// `TaskInstance.status` (R13). Bell badge counts where
/// `unread = true`. The entity is general so future notification
/// types can join without schema churn.
model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String
  taskInstanceId  String?
  unread          Boolean  @default(true)
  createdAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskInstance TaskInstance? @relation(fields: [taskInstanceId], references: [id], onDelete: SetNull)

  @@index([userId, unread])
  @@index([taskInstanceId])
}
